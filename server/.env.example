# Puerto donde corre el servicio
PORT=3000

# Clave secreta que el dashboard debe enviar en el header X-API-Key
# para poder listar grupos o disparar el envío de actualizaciones.
SEND_API_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Origen permitido para CORS (la URL donde vive el dashboard estático).
# Usa "*" solo para pruebas locales.
ALLOWED_ORIGIN=https://tu-usuario.github.io

# IDs de los grupos de WhatsApp a los que se enviará la actualización,
# separados por coma. Obtén los IDs llamando a GET /groups una vez
# que el cliente esté conectado (status READY).
# Formato típico: 123456789-987654321@g.us
WHATSAPP_GROUP_IDS=

# Ruta donde se persiste la sesión de WhatsApp (debe ser un volumen
# persistente en producción para no tener que re-escanear el QR).
WWEBJS_AUTH_PATH=.wwebjs_auth
